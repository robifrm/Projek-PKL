After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/vnet/backend

# Environment Variables - Database
Environment="DB_USERNAME=vnetuser"
Environment="DB_PASSWORD=VNet@DB2026!"

# Environment Variables - JWT (GANTI SEBELUM PRODUCTION!)
Environment="JWT_SECRET=vnet_production_secret_key_ganti_ini_sebelum_production_2026"
Environment="JWT_EXPIRATION_MS=86400000"

# Environment Variables - Resend Email
Environment="RESEND_API_KEY=re_YStab1af_PUR9isWWgJDSS7x8hfJ5UQF3"
Environment="RESEND_FROM_EMAIL=VNet <info.vnetsukabumi.id>"

